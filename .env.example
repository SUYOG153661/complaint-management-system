# Supabase Configuration
# Get these from your Supabase Project Settings -> API
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: If you use different variable names
# VITE_SUPABASE_PROJECT_URL=your-supabase-project-url
# VITE_SUPABASE_PUBLIC_ANON_KEY=your-supabase-anon-key

# Supabase Storage Bucket Name (default is 'complaints')
VITE_SUPABASE_BUCKET=complaints
